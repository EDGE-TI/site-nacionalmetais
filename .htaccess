Options +FollowSymLinks -MultiViews
RewriteEngine On
RewriteBase /

# 1. REMOVER A EXTENSÃO .HTML (Redirecionamento Externo)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# 2. ADICIONAR A EXTENSÃO INTERNAMENTE PARA PÁGINAS EXISTENTES
# Se existir o arquivo .html (ex: quem-somos.html), ele abre normal
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# 3. REGRA PARA POSTS DO BLOG (URLs AMIGÁVEIS)
# Se NÃO for um diretório E NÃO for um arquivo real E NÃO tiver o arquivo .html correspondente
# Então manda para o post.html passando o slug como parâmetro
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1.html !-f
RewriteRule ^([^/]+)/?$ post.html?slug=$1 [L,QSA]
