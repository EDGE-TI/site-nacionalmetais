RewriteEngine On

# 1. Redireciona externamente /arquivo.html para /arquivo (para SEO, evita conteúdo duplicado)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.html [NC]
RewriteRule ^ %1 [R=301,L]

# 2. Mapeia internamente /arquivo para /arquivo.html (para o servidor encontrar o arquivo)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]
