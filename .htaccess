Options +FollowSymLinks -MultiViews
RewriteEngine On
RewriteBase /

# 1. REMOVER A EXTENSÃO .HTML (Redirecionamento Externo)
# Se alguém digitar /contato.html, o navegador muda para /contato
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# 2. ADICIONAR A EXTENSÃO INTERNAMENTE (Reescrita Interna)
# Se o usuário digitar /contato, o servidor entrega contato.html
# Verifica se não é um diretório
RewriteCond %{REQUEST_FILENAME} !-d
# Verifica se o arquivo .html existe
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
